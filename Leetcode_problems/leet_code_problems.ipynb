   "source": [
    "**Q1.Given an input string s, reverse the order of the words.**"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "f6be2cde",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "blue is sky the\n"
     ]
    }
   ],
   "source": [
    "\n",
    "def reverseWords(s):\n",
    "    words =s.split()\n",
    "    words=words[::-1]\n",
    "    return \" \".join(words)\n",
    "\n",
    "print(reverseWords(\"the sky is blue\"))"
   ]
  },

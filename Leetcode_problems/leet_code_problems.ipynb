   ],
   "source": [
    "class Solution(object):\n",
    "    def reverseWords(self, s):\n",
    "        words =s.split()\n",
    "        words=words[::-1]\n",
    "        return \" \".join(words)\n",
    "\n",
    "    reversewords(\"the sky is blue\")"
   ]
